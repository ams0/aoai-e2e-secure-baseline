# Root .gitignore for AOAI E2E Secure Baseline
# Adjust as needed; entries below focus on Terraform, Bicep artifacts, secrets, and common OS/editor noise.

############################
# Terraform
############################
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# Local-only override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# Variable files that may contain secrets
terraform.tfvars
terraform.tfvars.json
*.auto.tfvars
# Keep only example var files
!terraform.tfvars.example

# Plan / output artifacts
*.plan
*.tfplan
terraform.plan

############################
# Bicep / ARM build artifacts (if you run 'bicep build')
############################
# Uncomment if you routinely build and do not wish to commit generated ARM templates
# *.json
# Parameter files sometimes generated by tooling
*.bicepparam.json

############################
# Certificates / Private Keys (rotate already committed secrets!)
############################
*.pem
*.key
*.crt
*.pfx
*.cer
*.der

############################
# Environment / Secrets
############################
.env
.env.*
*.env.local

############################
# Logs & Diagnostics
############################
logs/
*.log

############################
# macOS
############################
.DS_Store
.AppleDouble
.LSOverride

############################
# Editor / IDE
############################
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.code-workspace

############################
# Node.js (future-proof)
############################
node_modules/
yarn.lock
pnpm-lock.yaml
package-lock.json

############################
# Python (future-proof)
############################
.venv/
venv/
env/
__pycache__/
*.pyc

############################
# Misc
############################
*.swp
*.swo
*.tmp
*.bak
~$*
