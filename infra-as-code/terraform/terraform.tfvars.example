# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your actual values

# Resource Group Configuration
resource_group_name = "rg-aoai-secure-baseline"
location           = "East US 2"

# Base Configuration
base_name = "aoisec01"  # 6-8 characters for resource naming

# Domain and Certificate Configuration
custom_domain_name                = "contoso.com"
app_gateway_listener_certificate = "LS0tLS1CRUdJTi..." # Base64 encoded certificate

# Application Configuration
publish_file_name = "chatui.zip"

# Security Configuration
jump_box_admin_password = "YourSecurePassword123!" # Must meet complexity requirements
# your_principal_id is now automatically retrieved from your current Azure CLI/PowerShell context

# Telemetry Configuration
telemetry_opt_out = false